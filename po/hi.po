#. Translators: shown in the About dialog, put your name here.
#: src/window.rs:343
msgid "translator-credits"
msgstr "Scrambled777 <weblate.scrambled777@simplelogin.com>"

#. Translators: link title in the About dialog.
#: src/window.rs:346
msgid "Contribute Translations"
msgstr "अनुवाद में योगदान दें"

#: src/window.rs:354
msgid "Zoom level now takes into account fractional display scale."
msgstr "ज़ूम स्तर अब फ्रैक्शनल डिस्प्ले स्केल को ध्यान में रखता है।"

#: src/window.rs:355
msgid "Fixed unusably fast zoom on mice with high-resolution scroll wheels."
msgstr ""
"उच्च-रिज़ॉल्यूशन स्क्रॉल व्हील वाले माउस पर असामान्य रूप से तेज़ ज़ूम को ठीक किया गया।"

#: src/window.rs:356
msgid "Fixed slightly blurry image borders on some zoom levels."
msgstr "कुछ ज़ूम स्तरों पर थोड़ी धुंधली छवि सीमाओं को ठीक किया गया।"

#: src/window.rs:357
msgid "Updated to the GNOME 47 platform."
msgstr "गनोम 47 प्लेटफॉर्म पर अद्यतन किया गया।"

#: src/window.rs:358
msgid "Updated translations."
msgstr "अनुवाद अपडेट किये गये।"

#. Translators: Entry in the scale/zoom menu that indicates that the image or video is
#. always resized to fit the window.
#: src/window.rs:580
msgid "Best Fit"

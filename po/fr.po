#: data/resources/ui/window.blp:27 src/main.rs:36
msgid "Identity"
msgstr "Identity"

#. Translators: search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
#: data/org.gnome.gitlab.YaLTeR.Identity.desktop.in.in:10
msgid "Movie;Film;Clip;Difference;Frame;Quality;"
msgstr "Movie;Film;Clip;Difference;Frame;Quality;Film;Vidéo;Différence;Image;Qualité;"

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:10
msgid "A program for comparing multiple versions of an image or video."
msgstr "Un programme pour comparer de multiples versions d'une image ou vidéo."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:68
msgid "This release contains translation updates."
msgstr "Cette version contient des mises à jour de traduction."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:70
msgid "Added Dutch translation (thanks Heimen Stoffels)."
msgstr "Ajout d'une traduction néerlandaise (grâce à Heimen Stoffels)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:71
msgid "Added French translation (thanks Lapineige)."
msgstr "Ajout d'une traduction française (grâce à Lapineige)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:72
msgid "Added Spanish translation (thanks Óscar Fernández Díaz)."
msgstr "Ajout d'une traduction espagnole (grâce à Óscar Fernández Díaz)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:78
msgid "This release fixes minor UI issues."
msgstr "Cette version répare des problèmes mineurs d'interface."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:80
msgid "When closing a file, the next “tab” is now selected, or, if closing the last file, the previous one is selected."
msgstr "Lors de la fermeture d'un fichier, l'\"onglet\" suivant est désormais sélectionné, ou le précédent si c'est le dernier fichier."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:81
msgid "Fixed the application title not showing up upon closing all files."
msgstr "Répare un bug où le titre de l'application n'apparaissait pas au dessus de la fermeture de tous les fichiers."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:87
msgid "First release."
msgstr "Première version."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:107
msgid "Ivan Molodetskikh"
msgstr "Ivan Molodetskikh"

#. Translators: file chooser file filter name.
#: src/window.rs:1264
msgid "Videos and images"
msgstr "Vidéos et images"

#. Translators: file chooser dialog title.
#: src/window.rs:1275
msgid "Open videos or images to compare"
msgstr "Ouvrir les vidéos ou images à comparer"

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:50
msgid "This release contains translation updates and minor UI changes."
msgstr "Cette version contient des mises à jour de traduction et des changements d'interface mineurs."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:52
msgid "Video rotation tag is now respected."
msgstr "La balise de rotation des vidéos est maintenant respectée."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:53
msgid "Added Deutsch translation (thanks Johannes Hayeß)."
msgstr "Ajout d'une traduction allemande (grâce à Johannes Hayeß)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:54
msgid "Added Finnish translation (thanks Jiri Grönroos)."
msgstr "Ajout d'une traduction en finnois (grâce à Jiri Grönroos)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:55
msgid "Added Croatian translation (thanks Milo Ivir)."
msgstr "Ajout d'une traduction croate (grâce à Milo Ivir)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:56
msgid "Added Italian translation (thanks Blackcat-917)."
msgstr "Ajout d'une traduction italienne (grâce à Blackcat-917)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:57
msgid "Added Brazilian Portuguese translation (thanks Gustavo Costa)."
msgstr "Ajout d'une traduction portugaise (grâce à Gustavo Costa)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:58
msgid "Added Slovak translation (thanks Jose Riha)."
msgstr "Ajout d'une traduction slovaque (grâce à Jose Riha)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:59
msgid "Added Swedish translation (thanks Åke Engelbrektson)."
msgstr "Ajout d'une traduction suédoise (grâce à Åke Engelbrektson)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:60
msgid "Added translation contribution link."
msgstr "Ajout d'un lien pour contribuer au traductions."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:61
msgid "Specified input device recommendations to improve display in the new GNOME Software."
msgstr "Recommandations de périphériques d'entrée spécifiés pour améliorer l'affichage dans le nouveau GNOME Software."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:62
msgid "Label on the main window can now wrap so as not to restrict minimum window size."
msgstr "L'étiquette de la fenêtre principale peut maintenant être enveloppée afin de ne pas restreindre la taille minimale de la fenêtre."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:34
msgid "Identity is now a GTK 4 application!"
msgstr "Identity est maintenant une application en GTK 4 !"

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:36
msgid "Rewrote the application with GTK 4 and libadwaita."
msgstr "Réécriture de l'application avec GTK 4 et libadwaita."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:37
msgid "Added tabs to replace the old file switcher. You can drag tabs to rearrange them, drag a tab to split it into a new window, and drag tabs between windows."
msgstr "Ajout d'onglets pour remplacer l'ancien échangeur de fichier. Vous pouvez glisser-déposer les onglets pour les réarranger, en séparer un en une nouvelle fenêtre, et les déplacer entre plusieurs fenêtres."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:38
msgid "Changed the default style to dark."
msgstr "Style par défaut changé en sombre."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:39
msgid "Added Basque translation (thanks Sergio Varela)."
msgstr "Ajout d'une traduction basque (grâce à Sergio Varela)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:40
msgid "Added Galician translation (thanks Fran Diéguez)."
msgstr "Ajout d'une traduction galicienne (grâce à Fran Diéguez)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:41
msgid "Added Japanese translation (thanks Kaz Sibuya)."
msgstr "Ajout d'une traduction japonaise (grâce à Kaz Sibuya)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:42
msgid "Added Polish translation (thanks Rafał Baran)."
msgstr "Ajout d'une traduction polonaise (grâce à Rafał Baran)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:43
msgid "Added Chinese Simplified translation (thanks Garling Liang)."
msgstr "Ajout d'une traduction en chinois simplifié (grâce à Garling Liang)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:28
#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:44
msgid "Updated translations."
msgstr "Mise à jour de traductions."


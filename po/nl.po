msgid "Identity"
msgstr "Identiteit"

#. Translators: search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
#: data/org.gnome.gitlab.YaLTeR.Identity.desktop.in.in:10
msgid "Movie;Film;Clip;Difference;Frame;Quality;"
msgstr "Video;Film;Clip;Verschil;Vergelijk;Frame;Kwaliteit;"

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:10
msgid "A program for comparing multiple versions of an image or video."
msgstr "Een toepassing voor het vergelijken van meerdere versies van een afbeelding of video."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:103
msgid "This release contains translation updates."
msgstr "Deze versie bevat bijgewerkte vertalingen."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:105
msgid "Added Dutch translation (thanks Heimen Stoffels)."
msgstr "Nieuw: Nederlandse vertaling, met dank aan Heimen Stoffels."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:106
msgid "Added French translation (thanks Lapineige)."
msgstr "Nieuw: Franse vertaling, met dank aan Lapineige."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:107
msgid "Added Spanish translation (thanks Óscar Fernández Díaz)."
msgstr "Nieuw: Spaanse vertaling, met dank aan Óscar Fernández Diaz."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:113
msgid "This release fixes minor UI issues."
msgstr "In deze versie zijn enkele vormgevingsproblemen opgelost."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:115
msgid "When closing a file, the next “tab” is now selected, or, if closing the last file, the previous one is selected."
msgstr "Bij het sluiten van een bestand wordt voortaan het volgende tabblad geselecteerd of, bij het sluiten, het vorige."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:116
msgid "Fixed the application title not showing up upon closing all files."
msgstr "Opgelost: de toepassingstitel werd niet getoond bij het sluiten van alle bestanden."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:122
msgid "First release."
msgstr "Eerste uitgave."

#. Translators: name of the developer of the application.
#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:142
#: src/window.rs:360
msgid "Ivan Molodetskikh"
msgstr "Ivan Molodetskikh"

#. Translators: file chooser file filter name.
#: src/window.rs:1490
msgid "Videos and images"
msgstr "Afbeeldingen en video's"

#. Translators: file chooser dialog title.
#: src/window.rs:1501
msgid "Open videos or images to compare"
msgstr "Open te vergelijken afbeeldingen of video's"

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:85
msgid "This release contains translation updates and minor UI changes."
msgstr "Deze uitgave bevat bijgewerkte vertalingen en kleine aanpassingen aan de vormgeving."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:87
msgid "Video rotation tag is now respected."
msgstr "Videodraaiing wordt voortaan in acht genomen."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:88
msgid "Added Deutsch translation (thanks Johannes Hayeß)."
msgstr "Duitse vertaling (met dank aan Johannes Hayeß)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:89
msgid "Added Finnish translation (thanks Jiri Grönroos)."
msgstr "Finse vertaling (met dank aan Jiri Grönroos)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:90
msgid "Added Croatian translation (thanks Milo Ivir)."
msgstr "Kroatische vertaling (met dank aan Mili Ivir)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:91
msgid "Added Italian translation (thanks Blackcat-917)."
msgstr "Italiaanse vertaling (met dank aan @Blackcat-917)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:92
msgid "Added Brazilian Portuguese translation (thanks Gustavo Costa)."
msgstr "Braziliaans-Portugese vertaling (met dank aan Gustavo Costa)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:93
msgid "Added Slovak translation (thanks Jose Riha)."
msgstr "Slowaakse vertaling (met dank aan Jose Riha)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:94
msgid "Added Swedish translation (thanks Åke Engelbrektson)."
msgstr "Zweedse vertaling (met dank aan Åke Engelbrektson)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:95
msgid "Added translation contribution link."
msgstr "Vertaallink toegevoegd."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:96
msgid "Specified input device recommendations to improve display in the new GNOME Software."
msgstr "De invoerapparaat-aanbevelingen zijn verbeterd ten behoeve van de opname in GNOME Software."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:97
msgid "Label on the main window can now wrap so as not to restrict minimum window size."
msgstr "De labeltekst op het hoofdvenster wordt voortaan afgebroken (indien nodig) zodat er geen beperking meer is op de minimale vensterafmetingen."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:69
msgid "Identity is now a GTK 4 application!"
msgstr "Identity is een GTK4-toepassing!"

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:71
msgid "Rewrote the application with GTK 4 and libadwaita."
msgstr "De toepassing in herschreven in GTK4 en libadwaita."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:72
msgid "Added tabs to replace the old file switcher. You can drag tabs to rearrange them, drag a tab to split it into a new window, and drag tabs between windows."
msgstr "Nieuw: tabbladen in plaats van de bestandsschakelaar. U kunt tabbladen verslepen om ze te herordenen, afsplitsen naar een nieuw venster of verslepen tussen vensters."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:73
msgid "Changed the default style to dark."
msgstr "Nieuw: voortaan wordt standaard het donkere thema gebruikt."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:74
msgid "Added Basque translation (thanks Sergio Varela)."
msgstr "Nieuw: Baskische vertaling, met dank aan Sergio Varela."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:75
msgid "Added Galician translation (thanks Fran Diéguez)."
msgstr "Nieuw: Galicische vertaling, met dank aan Fran Diéguez."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:76
msgid "Added Japanese translation (thanks Kaz Sibuya)."
msgstr "Nieuw: Japanse vertaling, met dank aan Kaz Sibuya."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:77
msgid "Added Polish translation (thanks Rafał Baran)."
msgstr "Nieuw: Poolse vertaling, met dank aan Rafał Baran."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:78
msgid "Added Chinese Simplified translation (thanks Garling Liang)."
msgstr "Nieuw: Chinese vertaling, met dank aan Garling Liang."


#: data/resources/ui/window.blp:27 src/main.rs:35
msgid "Identity"
msgstr "Identidade"

#: data/org.gnome.gitlab.YaLTeR.Identity.desktop.in.in:4
#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:8
msgid "Compare images and videos"
msgstr "Compare imaxes e vídeos"

#. Translators: search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
#: data/org.gnome.gitlab.YaLTeR.Identity.desktop.in.in:10
msgid "Movie;Film;Clip;Difference;Frame;Quality;"
msgstr "Película;Filtme;Curta;Diferencia;Marco;Cualidade;"

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:10
msgid "A program for comparing multiple versions of an image or video."
msgstr "Un programa para comparar varias versións dunha imaxe ou vídeo."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:24
msgid "Identity is now a GTK 4 application!"
msgstr ""

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:26
msgid "Rewrote the application with GTK 4 and libadwaita."
msgstr ""

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:27
msgid ""
"Added tabs to replace the old file switcher. You can drag tabs to rearrange "
"them, drag a tab to split it into a new window, and drag tabs between "
"windows."
msgstr ""

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:28
msgid "Changed the default style to dark."
msgstr ""


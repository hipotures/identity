#: src/window.rs:350
msgid ""
"This release adds pixelated display for zoomed-in images and videos, "
"improves format support and fixes several issues."
msgstr "Bertsio honek bistaratze pixelatua gehitu du irudi eta bideo handiagotuetarako, formatuen euskarria hobetu du eta zenbait akats konpontu ditu."

#: src/window.rs:351
msgid "Zoomed-in images and videos are now pixelated rather than blurry."
msgstr "Orain, handiagotutako irudi eta bideoak pixelatu egingo dira, ez lausotu."

#: src/window.rs:352
msgid "Fixed memory usage not decreasing upon closing images and videos."
msgstr "Konpondu da irudiak eta bideoak ixtean memoria-erabilera jaitsi ez izana."

#: src/window.rs:353
msgid "Improved UI responsiveness with many open files."
msgstr "Fitxategi anitz irekita daudenean interfazeak duen erantzuna hobetu da."

#: src/window.rs:354
msgid "Improved performance on AV1 videos."
msgstr "Errendimendua honetau da AV1 bideoekin."

#: src/window.rs:355
msgid "Added support for WebP images."
msgstr "WebP irudien euskarria gehitu da."

#: src/window.rs:356
msgid "Fixed display of semitransparent images and videos."
msgstr "Irudi eta bideo erdi gardenen bistaratzea konpondu da."

#: src/window.rs:357
msgid "Fixed display of 16-bit color images."
msgstr "16 bit-eko koloreak dituzten irudien bistaratzea konpondu da."

#: src/window.rs:358
msgid "Removed panning from the touchpad pinch zoom gesture."
msgstr "Ukipen-panelaren atximurkatze eta handiagotzeko keinutik desplazamenduaren ekintza kendu da."

#: src/window.rs:360
msgid ""
"Fixed infinite loading spinner when opening certain files instead of error."
msgstr "Zenbait fitxategi irekitzean birakaria betiko biraka geratzea konpondu da, orain errore bat ematen da."

#: src/window.rs:362
msgid "Updated to the GNOME 45 platform."
msgstr "GNOME 45 plataformarako egokitu da."

#: src/window.rs:363
msgid "Updated translations."
msgstr "Eguneratutako itzulpenak."

#. Translators: Entry in the scale/zoom menu that indicates that the image or video is
#. always resized to fit the window.
#: src/window.rs:545
msgid "Best Fit"
msgstr "Egokiena"

#. Translators: file chooser file filter name.
#: src/window.rs:1577
msgid "Videos and images"
msgstr "Bideoak eta irudiak"

#. Translators: file chooser dialog title.
#: src/window.rs:1585
msgid "Open videos or images to compare"
msgstr "Ireki eta konparatu bideoak edo irudiak"


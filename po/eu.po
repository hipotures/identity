#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:10
msgid "A program for comparing multiple versions of an image or video."
msgstr "Irudi edo bideo baten bertsio batzuk alderatzeko programa bat."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:15
msgid "Main Window"
msgstr "Leiho nagusia"

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:43
msgid "This release contains translation updates."
msgstr "Bertsio honek itzulpenen eguneratzeak ditu."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:45
msgid "Added Dutch translation (thanks Heimen Stoffels)."
msgstr "Nederlanderazko itzulpena gehitu da (eskerrik asko Heimen Stoffels)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:46
msgid "Added French translation (thanks Lapineige)."
msgstr "Frantsesezko itzulpena gehitu da (eskerrik asko Lapineige)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:47
msgid "Added Spanish translation (thanks Óscar Fernández Díaz)."
msgstr "Gaztelaniazko itzulpena gehitu da (eskerrik asko Óscar Fernández Díaz)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:53
msgid "This release fixes minor UI issues."
msgstr "Bertsio horrek erabiltzaile-interfazearen arazo txikiak zuzentzen ditu."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:55
msgid "When closing a file, the next “tab” is now selected, or, if closing the last file, the previous one is selected."
msgstr "Fitxategi bat ixtean, orain \"erlaitz\" hau hautatuko da edo, azken fitxategia ixten bada, aurrekoa aukeratuko da."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:56
msgid "Fixed the application title not showing up upon closing all files."
msgstr "Zuzendu egin da aplikazioaren izenburua ez agertzea fitxategi guztiak ixtean."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:62
msgid "First release."
msgstr "Lehenengo jaurtiketa."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:79
msgid "Ivan Molodetskikh"
msgstr "Ivan Molodetskikh"


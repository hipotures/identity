#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:25
msgid "This release contains translation updates and minor UI changes."
msgstr "Bertsio honek itzulpen-eguneratzeak eta erabiltzaile-interfazearen aldaketa txikiak ditu."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:27
msgid "Video rotation tag is now respected."
msgstr "Orain bideoaren errotazio-etiketa errespetatzen da."


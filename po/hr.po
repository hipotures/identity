#: data/resources/ui/media_page.ui:60
msgctxt "Label shown when a video or image has failed to load."
msgid "Could not display the file.\n"
"\n"
"If you're running Identity under Flatpak, note that opening files by drag-and-drop and by pasting may not work."
msgstr "Datoteka se ne može prikazati.\n"
"\n"
"Ako se program „Identičnost” pokreće pod Flatpakom, otvaranje datoteka povlačenjem i ispuštanjem ili umetanjem možda neće raditi."


#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:72
msgid "Added Croatian translation (thanks Milo Ivir)."
msgstr "Dodan je prijevod na hrvatski (hvala Milo Ivir)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:73
msgid "Added Italian translation (thanks Blackcat-917)."

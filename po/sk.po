#. Translators: search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
#: data/org.gnome.gitlab.YaLTeR.Identity.desktop.in.in:10
msgid "Movie;Film;Clip;Difference;Frame;Quality;"
msgstr "Film;Klip;Rozdiel;Snímka;Kvalita;Video;Obrázok;"

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:10
msgid "A program for comparing multiple versions of an image or video."
msgstr "Program na porovnávanie viacerých verzií obrázku alebo videa."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:15
msgid "Main Window"
msgstr "Hlavné okno"

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:24
msgid "This release contains translation updates."
msgstr "Toto vydanie obsahuje aktualizácie prekladov."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:26
msgid "Added Dutch translation (thanks Heimen Stoffels)."
msgstr "Pridaný preklad do holandčiny (Heimen Stoffels)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:27
msgid "Added French translation (thanks Lapineige)."
msgstr "Pridaný preklad do francúzštiny (Lapineige)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:28
msgid "Added Spanish translation (thanks Óscar Fernández Díaz)."
msgstr "Pridaný preklad do španielčiny (Óscar Fernández Díaz)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:34
msgid "This release fixes minor UI issues."
msgstr "Toto vydanie obsahuje dropbné opravy používateľského rozhrania."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:36
msgid "When closing a file, the next “tab” is now selected, or, if closing the last file, the previous one is selected."
msgstr "Pri zatvorení súboru sa teraz aktivuje nasledujúci “panel”. V prípade, že zatvoríte posledný súbor, aktivuje sa predchádzajúci."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:37
msgid "Fixed the application title not showing up upon closing all files."
msgstr "Opravené zobrazenie názvu programu pri zatvorení všetkých súborov."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:43
msgid "First release."
msgstr "Prvé vydanie."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:55
msgid "Ivan Molodetskikh"
msgstr "Ivan Molodetskikh"


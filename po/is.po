msgstr "Fara áfram um einn ramma"

#: data/resources/ui/shortcuts.blp:63
msgctxt "shortcut window"
msgid "Step back one frame"
msgstr "Fara aftur um einn ramma"

#: data/resources/ui/shortcuts.blp:69

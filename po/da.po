#. Translators: "Not applicable" string for the media properties dialog when a
#. given property is unknown or missing (e.g. images don't have frame rate).
#: src/page.rs:274 src/window.rs:475 src/window.rs:483 src/window.rs:491
msgid "N/A"
msgstr "—"

#: src/window.rs:335
msgid "Added row and column tiled display modes for side-by-side comparison."
msgstr ""
"Visningstilstande tilføjet for fliselagte rækker og kolonner, så de kan "
"sammenlignes side om side."

#: src/window.rs:336
msgid ""
"Changed mouse scroll and hotkey zoom to have consistent speed regardless of "
"the current zoom level."
msgstr ""
"Muserulning og zoom med genvejstast ændret til at have samme hastighed "
"uanset det aktuelle zoomniveau."

#: src/window.rs:337
msgid ""
"Changed mouse scroll to zoom by default instead of panning, and to pan when "
"Ctrl is held."
msgstr ""
"Muserulning ændret til at zoome som standard i stedet for at panorere og til "
"at panorere, når Ctrl holdes nede."

#: src/window.rs:338
msgid ""
"Added panning by holding down the left mouse button and dragging when zoomed-"
"in."
msgstr ""
"Panorering ved at holde venstre museknap nede og trække, når der er zoomet "
"ind, tilføjet."

#: src/window.rs:339
msgid "Changed the playback position to update smoothly."
msgstr "Afspilningspositionen ændret, så den opdateres jævnt."

#: src/window.rs:340
msgid ""
"You can now drag-and-drop a file out of Identity when it is not zoomed-in."
msgstr ""
"Du kan nu trække-og-slippe en fil ud af Identity, når der ikke er zoomet ind."

#: src/window.rs:341
msgid "Added Ctrl+C to copy the current file to clipboard."
msgstr "Ctrl+C til kopiering af den aktuelle fil til udklipsholderen tilføjet."

#: src/window.rs:342
msgid "Added a context menu to tabs with a few common actions."
msgstr ""
"En genvejsmenu til faneblade med nogle få almindelige handlinger tilføjet."

#: src/window.rs:343
msgid ""
"Optimized video playback performance by enabling OpenGL video processing on "
"compatible setups."
msgstr ""
"Optimeret ydeevne ved videoafspilning ved aktivering af OpenGL-"
"videobehandling på kompatible opsætninger."

#: src/window.rs:344
msgid "Updated to the GNOME 44 platform."
msgstr "Opdateret til GNOME 44-platformen."

#: src/window.rs:345
msgid "Updated translations."
msgstr "Opdaterede oversættelser."

#: src/window.rs:348
msgid ""
"This release adds row and column display modes, reworks mouse gestures and "
"adds drag-and-drop from Identity."
msgstr ""
"I denne udgivelse er tilføjet visningstilstande for rækker og kolonner, "
"musebevægelser er bearbejdet og træk-og-slip fra Identity er tilføjet."


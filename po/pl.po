#: data/org.gnome.gitlab.YaLTeR.Identity.desktop.in.in:3
#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:7
msgid "Identity"
msgstr "Identity"

#. Translators: search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
#: data/org.gnome.gitlab.YaLTeR.Identity.desktop.in.in:10
msgid "Movie;Film;Clip;Difference;Frame;Quality;"
msgstr "Film;Film;Wycinek;Różnica;Klatka;Jakość;"

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:10
msgid "A program for comparing multiple versions of an image or video."
msgstr "Program do porównywania różnych wersji obrazu lub filmu."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:15
msgid "Main Window"
msgstr "Główne Okno"

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:43
msgid "This release contains translation updates."
msgstr "To wydanie zawiera aktualizacje tłumaczeń."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:45
msgid "Added Dutch translation (thanks Heimen Stoffels)."
msgstr "Dodano Holenderskie tłumaczenie (dzięki Heimen Stoffels)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:46
msgid "Added French translation (thanks Lapineige)."
msgstr "Dodano Francuskie tłumaczenie (dzięki Lapineige)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:47
msgid "Added Spanish translation (thanks Óscar Fernández Díaz)."
msgstr "‎Dodano hiszpańskie tłumaczenie (dzięki Óscar Fernández Díaz).‎"

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:53
msgid "This release fixes minor UI issues."
msgstr "To wydanie naprawia drobne problemy w interfejsie."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:55
msgid "When closing a file, the next “tab” is now selected, or, if closing the last file, the previous one is selected."
msgstr "Po zamknięciu pliku, następna \"karta\" jest teraz zaznaczona, lub, po zamknięciu ostatniego pliku, poprzednia karta jest zaznaczona."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:56
msgid "Fixed the application title not showing up upon closing all files."
msgstr "Naprawiono tytuł aplikacji nie pojawiający się po zamknięciu wszystkich plików."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:62
msgid "First release."
msgstr "Pierwsze wydanie."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:79
msgid "Ivan Molodetskikh"
msgstr "Ivan Molodetskikh"

#. Translators: startup error dialog text.
#: src/application.rs:29
msgid "Error loading Identity"
msgstr "Błąd podczas ładowania Identity"

#. Translators: startup error dialog secondary text.
#: src/application.rs:32
msgid "Could not create one of the required GStreamer elements (gtksink, playbin3)."
msgstr "Nie można utworzyć  jednego z wymaganych elementów GStreamer (gtksink, playbin3)."

#. Translators: file chooser file filter name.
#: src/window.rs:260
msgid "Videos and images"
msgstr "Filmy i obrazy"

#. Translators: file chooser dialog title.
#: src/window.rs:271
msgid "Open videos or images to compare"
msgstr "Otwórz filmy i obrazy do porównania"

#. Translators: placeholder shown in the headerbar for new files before their display
#. name is available (for example, when loading a file from a network mount).
#: src/window.rs:317
msgid "Loading…"
msgstr "Ładowanie…"

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:25
msgid "This release contains translation updates and minor UI changes."
msgstr "To wydanie zawiera aktualizacje tłumaczeń i drobne poprawki interfejsu."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:27
msgid "Video rotation tag is now respected."
msgstr "Tag obrotu filmu jest teraz przestrzegany."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:28
msgid "Added Deutsch translation (thanks Johannes Hayeß)."
msgstr "Dodano Niemieckie tłumaczenie (dzięki Johannes Hayeß)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:29
msgid "Added Finnish translation (thanks Jiri Grönroos)."
msgstr "Dodano Fińskie tłumaczenie (dzięki Jiri Grönroos)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:30
msgid "Added Croatian translation (thanks Milo Ivir)."
msgstr "Dodano Chorwackie tłumaczenie (dzięki Milo Ivir)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:31
msgid "Added Italian translation (thanks Blackcat-917)."
msgstr "Dodano Włoskie tłumaczenie (dzięki Blackcat-917)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:32
msgid "Added Brazilian Portuguese translation (thanks Gustavo Costa)."
msgstr "Dodano Brazylijskie Portugalskie tłumaczenie (dzięki Gustavo Costa)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:33
msgid "Added Slovak translation (thanks Jose Riha)."
msgstr "Dodano Słowackie tłumaczenie (dzięki Jose Riha)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:34
msgid "Added Swedish translation (thanks Åke Engelbrektson)."
msgstr "Dodano Szweckie tłumaczenie (dzięki Åke Engelbrektson)."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:35
msgid "Added translation contribution link."
msgstr "Dodano link do udziału w tłumaczeniu."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:36
msgid "Specified input device recommendations to improve display in the new GNOME Software."
msgstr "Określono rekomendowanie urządzenie wprowadzania żeby poprawić wyświetlanie w nowym GNOME Software."

#: data/org.gnome.gitlab.YaLTeR.Identity.metainfo.xml.in.in:37
msgid "Label on the main window can now wrap so as not to restrict minimum window size."
msgstr "Etykieta w oknie głównym teraz może mieć zawijany tekst, a co za tym idzie, mniej restrykcyjna minimalna wielkość okna."


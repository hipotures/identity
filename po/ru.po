#~ "приложении»."

#~ msgid "Added WebP images to the list of supported file types."
#~ msgstr "В список поддерживаемых типов файлов добавлены изображения WebP."

#~ msgid "Added Occitan translation (thanks Quentin PAGÈS)."
#~ msgstr "Добавлен перевод на окситанский (спасибо Quentin PAGÈS)."

#~ msgid "Added Serbian Cyrillic translation (thanks Јован Здравковић)."
#~ msgstr ""
#~ "Добавлен перевод на кириллический сербский (спасибо Јован Здравковић)."


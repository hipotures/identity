#~ msgid "This release adds zoom support."
#~ msgstr "В этой версии добавлено масштабирование."

#~ msgid ""
#~ "Added the ability to zoom in and out. You can use hotkeys, Ctrl + scroll, "
#~ "pinch zoom on a touchpad or touchscreen, or input the zoom factor "

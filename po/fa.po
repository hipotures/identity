#. Translators: Title that is shown upon video or image loading error.
#: data/resources/ui/page.blp:40
msgid "File Failed to Load"
msgstr "بار کردن پرونده شکست خورد"

#. Translators: Label shown when a video or image has failed to load.
#: data/resources/ui/page.blp:43
msgid ""
"Could not display the file.\n"
"\n"
"If you're running Identity under Flatpak, note that opening files by drag-and-"
"drop and by pasting may not work."
msgstr ""
"نتوانست پرونده را نشان دهد.\n"
"\n"
"اگر با فلت‌پک اجرا می‌کنید، به یاد داشته باشید که ممکن است گشودن پرونده‌ها با "
"کشیدن و رها کردن و با جایگذاری کار نکند."


#~ msgstr ""
#~ "Adicionada panorâmica ao manter pressionado o botão esquerdo do mouse e "
#~ "arrastar quando ampliado."

#~ msgid "Changed the playback position to update smoothly."
#~ msgstr "A posição de reprodução foi alterada para atualizar suavemente."

#~ msgid ""

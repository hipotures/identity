msgid "Open videos or images"
msgstr "פתיחת סרטים או תמונות"

#: data/resources/ui/shortcuts.blp:19
msgctxt "shortcut window"
msgid "Open file from clipboard"
msgstr "פתיחת קובץ מלוח הגזירים"


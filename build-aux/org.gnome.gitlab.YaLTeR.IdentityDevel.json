{
    "app-id" : "org.gnome.gitlab.YaLTeR.IdentityDevel",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "3.38",
    "sdk" : "org.gnome.Sdk",
    "sdk-extensions" : [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "add-extensions": {
        "org.freedesktop.Platform.ffmpeg-full": {
            "directory": "lib/ffmpeg",
            "version": "20.08",
            "add-ld-path": "."
        }
    },
    "cleanup-commands": [
        "mkdir -p ${FLATPAK_DEST}/lib/ffmpeg"
    ],
    "command" : "identity",
    "tags" : [
        "nightly"
    ],
    "desktop-file-name-suffix" : " (Devel)",
    "finish-args" : [
        "--env=RUST_BACKTRACE=1",
        "--env=G_MESSAGES_DEBUG=Identity",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri"
    ],
    "build-options" : {
        "append-path" : "/usr/lib/sdk/rust-stable/bin",
        "build-args" : [
            "--share=network"
        ]
    },
    "modules" : [
        {
            "name" : "libhandy",
            "buildsystem" : "meson",
            "config-opts" : [
                "-Dintrospection=disabled",
                "-Dvapi=false",
                "-Dtests=false",
                "-Dexamples=false",
                "-Dglade_catalog=disabled"
            ],
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://gitlab.gnome.org/GNOME/libhandy.git",
                    "tag" : "1.0.0"
                }
            ]
        },
        {
            "name" : "identity",
            "buildsystem" : "meson",
            "builddir": true,
            "config-opts" : [
                "-Dprofile=development"
            ],
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://gitlab.gnome.org/YaLTeR/identity.git"
                }
            ]
        }
    ]
}


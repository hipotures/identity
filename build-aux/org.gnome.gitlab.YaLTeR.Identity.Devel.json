{
    "app-id": "org.gnome.gitlab.YaLTeR.Identity.Devel",
    "runtime": "org.gnome.Platform",
    "runtime-version": "master",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": ["org.freedesktop.Sdk.Extension.rust-stable"],
    "add-extensions": {
        "org.freedesktop.Platform.ffmpeg-full": {
            "directory": "lib/ffmpeg",
            "version": "23.08",
            "add-ld-path": "."
        }
    },
    "cleanup-commands": [
        "mkdir -p ${FLATPAK_DEST}/lib/ffmpeg"
    ],
    "cleanup": [
        "/bin/blueprint-compiler",
        "/lib/pkgconfig"
    ],
    "command": "identity",
    "tags": [
        "nightly"
    ],
    "desktop-file-name-suffix": " (Devel)",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--env=GSK_RENDERER=ngl",
        "--env=RUST_LOG=identity=debug",
        "--env=RUST_BACKTRACE=1"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin",
        "build-args": [
            "--share=network"
        ]
    },
    "modules": [
        {
            "name": "blueprint",
            "buildsystem": "meson",
            "cleanup": ["*"],
            "sources": [
                {
                    "type": "git",
                    "url": "https://gitlab.gnome.org/jwestman/blueprint-compiler.git",
                    "commit": "66b43c36cf1017c878762007373964a096b3d2a5"
                }
            ]
        },
        {
            "name": "identity",
            "buildsystem": "meson",
            "builddir": true,
            "config-opts": ["-Dprofile=development"],
            "sources": [
                {
                    "type": "dir",
                    "path": ".."
                }
            ]
        }
    ]
}

<?xml version="1.0" encoding="UTF-8"?>
<!-- Ivan Molodetskikh 2020-2022 <yalterz@gmail.com> -->
<component type="desktop-application">
  <id>@app-id@</id>
  <metadata_license>CC0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <name>Identity</name>
  <summary>Compare images and videos</summary>
  <description>
    <p>A program for comparing multiple versions of an image or video.</p>
  </description>
  <screenshots>
    <screenshot type="default">
      <image>https://gitlab.gnome.org/YaLTeR/identity/uploads/0876907d00c9737d5bb5376a82255baa/row.png</image>
      <caption>You can arrange videos in a row</caption>
    </screenshot>
    <screenshot>
      <image>https://gitlab.gnome.org/YaLTeR/identity/uploads/7c5a7d2191b259f7c846226f7e074826/column.png</image>
      <caption>You can arrange images in a column</caption>
    </screenshot>
    <screenshot>
      <image>https://gitlab.gnome.org/YaLTeR/identity/uploads/2c6d515c5a952d14829be99a1bada08c/tab.png</image>
      <caption>You can open files as tabs</caption>
    </screenshot>
    <screenshot>
      <image>https://gitlab.gnome.org/YaLTeR/identity/uploads/fc69820af95cb95231936b185c4e061f/media-properties.png</image>
      <caption>Inspect a few properties of a video in a dialog</caption>
    </screenshot>
  </screenshots>
  <url type="homepage">https://gitlab.gnome.org/YaLTeR/identity</url>
  <url type="bugtracker">https://gitlab.gnome.org/YaLTeR/identity/issues</url>
  <url type="translate">https://l10n.gnome.org/module/identity/</url>
  <url type="vcs-browser">https://gitlab.gnome.org/YaLTeR/identity</url>
  <content_rating type="oars-1.1" />
  <releases>
    <release version="0.6.0" date="2023-09-22">
      <description>
        <p>This release adds pixelated display for zoomed-in images and videos, improves format support and fixes several issues.</p>
        <ul>
          <li>Zoomed-in images and videos are now pixelated rather than blurry.</li>
          <li>Fixed memory usage not decreasing upon closing images and videos.</li>
          <li>Improved UI responsiveness with many open files.</li>
          <li>Improved performance on AV1 videos.</li>
          <li>Added support for WebP images.</li>
          <li>Fixed display of semitransparent images and videos.</li>
          <li>Fixed display of 16-bit color images.</li>
          <li>Removed panning from the touchpad pinch zoom gesture.</li>
          <li>Fixed infinite loading spinner when opening certain files instead of error.</li>
          <li>Updated to the GNOME 45 platform.</li>
          <li>Updated translations.</li>
        </ul>
      </description>
    </release>
    <release version="0.5.0" date="2023-03-22">
      <description>
        <p>This release adds row and column display modes, reworks mouse gestures and adds drag-and-drop from Identity.</p>
        <ul>
          <li>Added row and column tiled display modes for side-by-side comparison.</li>
          <li>Changed mouse scroll and hotkey zoom to have consistent speed regardless of the current zoom level.</li>
          <li>Changed mouse scroll to zoom by default instead of panning, and to pan when Ctrl is held.</li>
          <li>Added panning by holding down the left mouse button and dragging when zoomed-in.</li>
          <li>Changed the playback position to update smoothly.</li>
          <li>You can now drag-and-drop a file out of Identity when it is not zoomed-in.</li>
          <li>Added Ctrl+C to copy the current file to clipboard.</li>
          <li>Added a context menu to tabs with a few common actions.</li>
          <li>Optimized video playback performance by enabling OpenGL video processing on compatible setups.</li>
          <li>Updated to the GNOME 44 platform.</li>
          <li>Updated translations.</li>
        </ul>
      </description>
    </release>
    <release version="0.4.0" date="2022-10-21">
      <description>
        <p>This release adds a media properties dialog and updates Identity to the GNOME 43 platform.</p>
        <ul>
          <li>Added a media properties dialog which will display information about the currently open file.</li>
          <li>Tab tooltips now show full file paths, which is useful when comparing files with identical names.</li>
          <li>Updated to the GNOME 43 platform, which brings the ability to drag-and-drop from Files on Flatpak and a refreshed About dialog.</li>
          <li>Added WebP images to the list of supported file types.</li>
          <li>Added Occitan translation (thanks Quentin PAGÈS).</li>
          <li>Added Serbian Cyrillic translation (thanks Јован Здравковић).</li>
          <li>Added Tamil translation (thanks க.பா.தருண் கிருஷ்ணா).</li>
          <li>Added Turkish translation (thanks Sabri Ünal).</li>
          <li>Added Chinese Traditional translation (thanks Kisaragi Hiu).</li>
          <li>Updated translations.</li>
        </ul>
      </description>
    </release>
    <release version="0.3.0" date="2022-03-31">
      <description>
        <p>This release adds zoom support.</p>
        <ul>
          <li>Added the ability to zoom in and out. You can use hotkeys, Ctrl + scroll, pinch zoom on a touchpad or touchscreen, or input the zoom factor manually. Zoom and view position are synchronized between the open files.</li>
          <li>Added Czech translation (thanks Jaroslav Svoboda).</li>
          <li>Updated translations.</li>
        </ul>
      </description>
    </release>
    <release version="0.2.0" date="2022-03-21">
      <description>
        <p>Identity is now a GTK 4 application!</p>
        <ul>
          <li>Rewrote the application with GTK 4 and libadwaita.</li>
          <li>Added tabs to replace the old file switcher. You can drag tabs to rearrange them, drag a tab to split it into a new window, and drag tabs between windows.</li>
          <li>Changed the default style to dark.</li>
          <li>Added Basque translation (thanks Sergio Varela).</li>
          <li>Added Galician translation (thanks Fran Diéguez).</li>
          <li>Added Japanese translation (thanks Kaz Sibuya).</li>
          <li>Added Polish translation (thanks Rafał Baran).</li>
          <li>Added Chinese Simplified translation (thanks Garling Liang).</li>
          <li>Updated translations.</li>
        </ul>
      </description>
    </release>
    <release version="0.1.3" date="2021-09-09">
      <description>
        <p>This release contains translation updates and minor UI changes.</p>
        <ul>
          <li>Video rotation tag is now respected.</li>
          <li>Added Deutsch translation (thanks Johannes Hayeß).</li>
          <li>Added Finnish translation (thanks Jiri Grönroos).</li>
          <li>Added Croatian translation (thanks Milo Ivir).</li>
          <li>Added Italian translation (thanks Blackcat-917).</li>
          <li>Added Brazilian Portuguese translation (thanks Gustavo Costa).</li>
          <li>Added Slovak translation (thanks Jose Riha).</li>
          <li>Added Swedish translation (thanks Åke Engelbrektson).</li>
          <li>Added translation contribution link.</li>
          <li>Specified input device recommendations to improve display in the new GNOME Software.</li>
          <li>Label on the main window can now wrap so as not to restrict minimum window size.</li>
        </ul>
      </description>
    </release>
    <release version="0.1.2" date="2021-01-03">
      <description>
        <p>This release contains translation updates.</p>
        <ul>
          <li>Added Dutch translation (thanks Heimen Stoffels).</li>
          <li>Added French translation (thanks Lapineige).</li>
          <li>Added Spanish translation (thanks Óscar Fernández Díaz).</li>
        </ul>
      </description>
    </release>
    <release version="0.1.1" date="2020-10-12">
      <description>
        <p>This release fixes minor UI issues.</p>
        <ul>
          <li>When closing a file, the next “tab” is now selected, or, if closing the last file, the previous one is selected.</li>
          <li>Fixed the application title not showing up upon closing all files.</li>
        </ul>
      </description>
    </release>
    <release version="0.1.0" date="2020-10-01">
      <description>
        <p>First release.</p>
      </description>
    </release>
  </releases>
  <kudos>
    <!--
      GNOME Software kudos:
      https://gitlab.gnome.org/GNOME/gnome-software/blob/master/doc/kudos.md
    -->
    <kudo>ModernToolkit</kudo>
    <kudo>HiDpiIcon</kudo>
  </kudos>
  <recommends>
    <control>pointing</control>
    <control>keyboard</control>
    <control>touch</control>
  </recommends>
  <requires>
    <display_length compare="ge">360</display_length>
  </requires>
  <!-- developer_name tag deprecated with Appstream 1.0 -->
  <developer_name>Ivan Molodetskikh</developer_name>
  <developer id="rs.bxt">
    <name>Ivan Molodetskikh</name>
  </developer>
  <update_contact>yalterz@gmail.com</update_contact>
  <translation type="gettext">@gettext-package@</translation>
  <launchable type="desktop-id">@app-id@.desktop</launchable>
</component>

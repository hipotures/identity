<?xml version="1.0" encoding="UTF-8"?>
<!-- Ivan Molodetskikh 2020 <yalterz@gmail.com> -->
<component type="desktop-application">
  <id>@app-id@</id>
  <metadata_license>CC0</metadata_license>
  <project_license>GPL-3.0+</project_license>
  <name>Identity</name>
  <summary>Compare images and videos</summary>
  <description>
    <p>A program for comparing multiple versions of an image or video.</p>
  </description>
  <screenshots>
    <screenshot type="default">
      <image>https://gitlab.gnome.org/YaLTeR/identity/raw/master/data/resources/screenshots/screenshot1.png</image>
      <caption>Main Window</caption>
    </screenshot>
  </screenshots>
  <url type="homepage">https://gitlab.gnome.org/YaLTeR/identity</url>
  <url type="bugtracker">https://gitlab.gnome.org/YaLTeR/identity/issues</url>
  <url type="translate">https://poeditor.com/join/project?hash=5nahahJe7Z</url>
  <content_rating type="oars-1.0" />
  <releases>
    <release version="0.2.0" date="2022-03-21">
      <description>
        <ul>
          <li>Added Basque translation (thanks Sergio Varela).</li>
          <li>Added Galician translation (thanks Fran Diéguez).</li>
          <li>Added Japanese translation (thanks Kaz Sibuya).</li>
          <li>Added Polish translation (thanks Rafał Baran).</li>
          <li>Added Chinese Simplified translation (thanks Garling Liang).</li>
          <li>Updated translations.</li>
        </ul>
      </description>
    </release>
    <release version="0.1.3" date="2021-09-09">
      <description>
        <p>This release contains translation updates and minor UI changes.</p>
        <ul>
          <li>Video rotation tag is now respected.</li>
          <li>Added Deutsch translation (thanks Johannes Hayeß).</li>
          <li>Added Finnish translation (thanks Jiri Grönroos).</li>
          <li>Added Croatian translation (thanks Milo Ivir).</li>
          <li>Added Italian translation (thanks Blackcat-917).</li>
          <li>Added Brazilian Portuguese translation (thanks Gustavo Costa).</li>
          <li>Added Slovak translation (thanks Jose Riha).</li>
          <li>Added Swedish translation (thanks Åke Engelbrektson).</li>
          <li>Added translation contribution link.</li>
          <li>Specified input device recommendations to improve display in the new GNOME Software.</li>
          <li>Label on the main window can now wrap so as not to restrict minimum window size.</li>
        </ul>
      </description>
    </release>
    <release version="0.1.2" date="2021-01-03">
      <description>
        <p>This release contains translation updates.</p>
        <ul>
          <li>Added Dutch translation (thanks Heimen Stoffels).</li>
          <li>Added French translation (thanks Lapineige).</li>
          <li>Added Spanish translation (thanks Óscar Fernández Díaz).</li>
        </ul>
      </description>
    </release>
    <release version="0.1.1" date="2020-10-12">
      <description>
        <p>This release fixes minor UI issues.</p>
        <ul>
          <li>When closing a file, the next “tab” is now selected, or, if closing the last file, the previous one is selected.</li>
          <li>Fixed the application title not showing up upon closing all files.</li>
        </ul>
      </description>
    </release>
    <release version="0.1.0" date="2020-10-01">
      <description>
        <p>First release.</p>
      </description>
    </release>
  </releases>
  <kudos>
    <!--
      GNOME Software kudos:
      https://gitlab.gnome.org/GNOME/gnome-software/blob/master/doc/kudos.md
    -->
    <kudo>ModernToolkit</kudo>
    <kudo>HiDpiIcon</kudo>
  </kudos>
  <recommends>
    <control>pointing</control>
    <control>keyboard</control>
    <control>touch</control>
  </recommends>
  <developer_name>Ivan Molodetskikh</developer_name>
  <update_contact>yalterz@gmail.com</update_contact>
  <translation type="gettext">@gettext-package@</translation>
  <launchable type="desktop-id">@app-id@.desktop</launchable>
</component>
